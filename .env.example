# ── NextAuth ──────────────────────────────────────────────────────────────────
# Set to your deployed Vercel URL, or http://localhost:3000 for local dev
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=replace-with-any-random-32-char-string

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Plain text password (fine for a private admin tool):
ADMIN_PASSWORD=your-password-here
# OR bcrypt hash (more secure):
# Generate with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
# ADMIN_PASSWORD_HASH=$2b$10$...

# ── Google Drive ──────────────────────────────────────────────────────────────
# Used for: storing uploaded templates/xlsx (on Vercel), certificate PNGs, and
# tournament metadata. All stored in your Google Drive — no other service needed.
#
# Setup:
# 1. Go to console.cloud.google.com → New project → Enable "Google Drive API"
# 2. IAM & Admin → Service Accounts → Create → Download JSON key
# 3. Paste the entire JSON as a single line below (no line breaks)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
